{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "AdfMedallionProjectKeshav"
		},
		"datalake_ls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake_ls'"
		},
		"ls_AzureSqlDB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_AzureSqlDB'"
		},
		"ls_onPremFile_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_onPremFile'"
		},
		"AzureDatabricks_LS_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0624-102401-ejz0soow"
		},
		"Https_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"datalake_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfkeshavstorage.dfs.core.windows.net/"
		},
		"ls_AzureSqlDB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adfprojectserver123.database.windows.net"
		},
		"ls_AzureSqlDB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfprojectDB"
		},
		"ls_AzureSqlDB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "serveradmin"
		},
		"ls_onPremFile_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "C:\\Users\\user\\OneDrive\\Documents\\ADF_Project"
		},
		"ls_onPremFile_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "raghuvanshikeshav9@gmail.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "AdfMedallionProjectKeshav_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"datalake_ls_accountKey": {
						"value": "[parameters('datalake_ls_accountKey')]"
					},
					"ls_AzureSqlDB_password": {
						"value": "[parameters('ls_AzureSqlDB_password')]"
					},
					"ls_onPremFile_password": {
						"value": "[parameters('ls_onPremFile_password')]"
					},
					"AzureDatabricks_LS_properties_typeProperties_existingClusterId": {
						"value": "[parameters('AzureDatabricks_LS_properties_typeProperties_existingClusterId')]"
					},
					"Https_ls_properties_typeProperties_url": {
						"value": "[parameters('Https_ls_properties_typeProperties_url')]"
					},
					"datalake_ls_properties_typeProperties_url": {
						"value": "[parameters('datalake_ls_properties_typeProperties_url')]"
					},
					"ls_AzureSqlDB_properties_typeProperties_server": {
						"value": "[parameters('ls_AzureSqlDB_properties_typeProperties_server')]"
					},
					"ls_AzureSqlDB_properties_typeProperties_database": {
