					},
					"ls_AzureSqlDB_properties_typeProperties_userName": {
						"value": "[parameters('ls_AzureSqlDB_properties_typeProperties_userName')]"
					},
					"ls_onPremFile_properties_typeProperties_host": {
						"value": "[parameters('ls_onPremFile_properties_typeProperties_host')]"
					},
					"ls_onPremFile_properties_typeProperties_userId": {
						"value": "[parameters('ls_onPremFile_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
